# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Bakong API Configuration
BAKONG_API_URL=https://api-bakong.nbc.org.kh
BAKONG_API_KEY=your_bakong_api_key_here
BAKONG_MERCHANT_ID=your_merchant_id_here

# Database Configuration
DATABASE_URL=sqlite:///./sales.db
# For production: postgresql://user:password@localhost/dbname

# Application Settings
NODE_ENV=development
PORT=3000

# Branch Configuration (comma-separated)
BRANCHES=Branch1,Branch2,Branch3

# Admin Telegram User IDs (comma-separated)
ADMIN_USER_IDS=123456789,987654321
