# ========================================
# Bakong Vendor Bot Configuration
# ========================================

# REQUIRED: Telegram Bot Token
# Get this from @BotFather on Telegram
# 1. Search for @BotFather
# 2. Send /newbot
# 3. Follow instructions
# 4. Copy the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# REQUIRED: Branch Configuration
# List your branches separated by commas
# Example: Central Market,Russian Market,Olympic Market
BRANCHES=Central Market,Russian Market,Olympic Market

# Application Settings
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ========================================
# Database Configuration (NEW!)
# ========================================
# Choose database type: 'json' or 'mongodb'
# - json: Simple file-based storage (good for single device testing)
# - mongodb: Production database (required for multi-device access)
DATABASE_TYPE=json

# MongoDB Configuration (only needed if DATABASE_TYPE=mongodb)
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/bakong-bot
# 
# MongoDB Atlas (Cloud - Recommended for production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bakong-bot
#
# Docker MongoDB:
# MONGODB_URI=mongodb://admin:changeme123@localhost:27017/bakong-bot?authSource=admin
MONGODB_URI=mongodb://localhost:27017/bakong-bot

# ========================================
# Logging Configuration
# ========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ========================================
# Optional: Bakong API Integration
# ========================================
# Only needed if you want real-time verification
# Contact Bakong for API access

BAKONG_API_URL=https://api-bakong.nbc.org.kh
BAKONG_API_KEY=your_bakong_api_key_here
BAKONG_MERCHANT_ID=your_merchant_id_here

# ========================================
# Admin Configuration
# ========================================
# Telegram User IDs of administrators
# Get your ID by sending /start to @userinfobot
# Separate multiple IDs with commas
ADMIN_USER_IDS=

